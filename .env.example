# LLM
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-opus-4-7

# LiteLLM fallback
OPENAI_API_KEY=
LITELLM_API_BASE=

# Infrastructure
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://agentforge:agentforge@localhost:5432/agentforge
S3_BUCKET=agentforge-outputs
S3_ENDPOINT=https://s3.amazonaws.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Tool APIs
TAVILY_API_KEY=
VERISK_API_KEY=
WESTLAW_API_KEY=

# Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=agentforge

# Platform
JWT_SECRET=change-me-in-prod
API_KEY_SALT=change-me-in-prod
STRIPE_SECRET_KEY=
NODE_ENV=development
LOG_LEVEL=info

# Service ports
API_GATEWAY_PORT=3000
WORKER_PORT=3001
STUDIO_PORT=3002
